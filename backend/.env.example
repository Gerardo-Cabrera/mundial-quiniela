# Database
# PostgreSQL nativo del host (setup único del rol/BD: ver docker-compose.yml).
DATABASE_URL=postgresql+asyncpg://mundial:mundial_pass@localhost:5432/mundial_quiniela

# Security
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# API-Football: dos formas de acceder a la MISMA API (elige según tu cuenta).
#
# Opción A — acceso DIRECTO api-sports.io (key de 32 chars, recomendado):
#   https://dashboard.api-football.com/  → "My Access"
API_FOOTBALL_KEY=your_apisports_key_here
API_FOOTBALL_PROVIDER=apisports
API_FOOTBALL_HOST=v3.football.api-sports.io
#
# Opción B — vía RapidAPI (key de ~50 chars):
#   https://rapidapi.com/api-sports/api/api-football
#   API_FOOTBALL_PROVIDER=rapidapi
#   API_FOOTBALL_HOST=api-football-v1.p.rapidapi.com
#
# (API_FOOTBALL_PROVIDER=auto deduce el proveedor por el host.)

# Mundial FIFA en API-Football: league ID = 1, temporada = 2026
LEAGUE_ID=1
SEASON=2026
# Zona horaria (IANA) para agrupar partidos por jornada/día y calcular el cierre
# de pronósticos (1 h antes del primer partido del día).
#TOURNAMENT_TZ=America/Mexico_City

# App
APP_ENV=development
# Varios orígenes: separar por comas (ej: http://localhost:5174,https://miapp.com)
CORS_ORIGINS=http://localhost:5174

# Rate limiting (opcional; valores por defecto en config.py).
# Descomentar para sobreescribir. En desarrollo se suele desactivar.
#RATE_LIMIT_ENABLED=true
#RATE_LIMIT_DEFAULT=60/minute
# Límite reforzado solo en /auth/* (login y registro), anti fuerza bruta:
#RATE_LIMIT_AUTH=10/minute
# Límite en los syncs admin (/matches/sync, /config/teams/sync); protege la
# cuota de API-Football (plan Free: 100 req/día):
#RATE_LIMIT_SYNC=10/hour
